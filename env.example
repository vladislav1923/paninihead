# Same name locally and on Vercel (Vercel injects POSTGRES_URL)
POSTGRES_URL="postgresql://user:password@localhost:6000/paninihead"

# Playwright e2e: `db-e2e` in docker-compose (port 6001). Same Prisma migrations run against this URL in global setup.
POSTGRES_URL_E2E="postgresql://user:password@localhost:6001/paninihead_e2e"